# Tuzi API Configuration
# Banana-2 模型密钥（默认模型）
TUZI_API_TOKEN=your_banana2_api_token_here

# GPT Image-2 模型专用密钥（选填，不配置则 image-2 不可用）
TUZI_IMAGE2_TOKEN=your_image2_api_token_here
TUZI_API_BASE_URL=https://api.tu-zi.com/v1

# Server Configuration
PORT=3001
NODE_ENV=development

# Polling config (ms)
POLL_INTERVAL=10000
POLL_TIMEOUT=600000
